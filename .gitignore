node_modules/

# Cloudflare Pages and CI temp
/.cache/

# Optional local environment files
.env
.env.local
.env.*.local

# Ignore generated site manifest if built locally
/public/**/CNAME

# Lock file for Hugo build process
.hugo_build.lock