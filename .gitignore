/public/
/resources/
/hugo_stats.json

# OS files
.DS_Store
Thumbs.db

# Editor configs
.vscode/
.idea/
*.swp
*~

# Logs and temp files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

